function saveMT() {
  const topic = document.getElementById('mt-topic').value.trim();
  if (!topic) { alert('กรุณากรอกหัวข้อ'); return; }
  const newId = (state.morningTalks.length ? Math.max(...state.morningTalks.map(m=>m.id)) : 0) + 1;
  state.morningTalks.push({ id: newId, date: document.getElementById('mt-date').value, branch: document.getElementById('mt-branch').value, topic, progress: document.getElementById('mt-prog').value, owner: state.currentUser?.display || '—', note: document.getElementById('mt-note').value.trim() });
  saveState(); closeModal('modal-mt'); renderAll();
}

// ═══════════════════════════════════════
// UI HELPERS
// ═══════════════════════════════════════
function show(id) { document.getElementById(id)?.classList.add('active'); }
function hide(id) { document.getElementById(id)?.classList.remove('active'); }
function openModal(id) { document.getElementById(id)?.classList.add('open'); }
function closeModal(id) { document.getElementById(id)?.classList.remove('open'); }

function switchTab(el, tabId) {
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(t=>t.style.display='none');
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  if (el) el.classList.add('active');
  const tc = document.getElementById('tab-'+tabId);
  if (tc) tc.style.display = 'block';
  const navBtns = document.querySelectorAll('.nav-btn');
  const tabMap = {dashboard:0,mytasks:1,team:2,notifs:3};
  if (navBtns[tabMap[tabId]]) navBtns[tabMap[tabId]].classList.add('active');
}

// Close modals on overlay click
document.querySelectorAll('.modal-overlay').forEach(o => {
  o.addEventListener('click', e => { if (e.target===o) o.classList.remove('open'); });
});

