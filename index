<script>
// ═══════════════════════════════════════
// DATA & STATE
// ═══════════════════════════════════════
const STORAGE_KEY = 'hanheng_mt_v2';
let state = {
  currentUser: null,
  tasks: [],
  morningTalks: [],
  editTaskId: null
};

function loadState() {
  try { const s = localStorage.getItem(STORAGE_KEY); if (s) state = {...state, ...JSON.parse(s)}; } catch(e){}
}
function saveState() {
  const s = {...state}; delete s.currentUser;
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(s)); } catch(e){}
}

// ═══════════════════════════════════════
// SEED DATA (first load)
// ═══════════════════════════════════════
function seedData() {
  if (state.tasks.length > 0) return;
  const today = new Date();
  const fmt = d => d.toISOString().split('T')[0];
  const addDays = (d,n) => { const x=new Date(d); x.setDate(x.getDate()+n); return x; };

  state.tasks = [
    { id: 1, name: 'ติดตามงานค้าง', group: 'หน้าร้าน', owner: 'ทุกคน', start: fmt(today), due: fmt(addDays(today,2)), remind: 1, status: 'กำลังดำเนินการ', pct: 100, checklist: ['ตรวจรายการค้าง','ติดต่อลูกค้า','บันทึกผล'].map(t=>({t,done:true})), notes: 'ดำเนินการเสร็จสิ้น' },
    { id: 2, name: 'จัดทำไฟล์วางบิล คุณชินดี้', group: 'Back office', owner: 'เนตร', start: fmt(today), due: fmt(addDays(today,1)), remind: 1, status: 'กำลังดำเนินการ', pct: 100, checklist: ['รวบรวมใบแจ้งหนี้','จัดทำไฟล์','ส่งลูกค้า'].map(t=>({t,done:true})), notes: '' },
    { id: 3, name: 'จัดทำไฟล์วางบิล คุณคีวฯ อัพเดท ล็อตที่3', group: 'Back office', owner: 'เนตร', start: fmt(today), due: fmt(addDays(today,3)), remind: 1, status: 'กำลังดำเนินการ', pct: 25, checklist: ['รวบรวมข้อมูล','จัดทำไฟล์','ตรวจสอบ','ส่ง'].map(t=>({t,done:false})), notes: 'กำลังดำเนินการ' },
    { id: 4, name: 'ปันทึกรายจ่าย-รายรับ/เตรียมเอกสารส่ง สนง บัญชี', group: 'Back office', owner: 'เนตร', start: fmt(addDays(today,-2)), due: fmt(addDays(today,0)), remind: 1, status: 'กำลังดำเนินการ', pct: 50, checklist: ['รวบรวมเอกสาร','ตรวจสอบยอด','จัดทำสรุป','ส่งสำนักงานบัญชี'].map(t=>({t,done:t==='รวบรวมเอกสาร'})), notes: '' },
    { id: 5, name: 'สั่งของด้าย', group: 'งานตัด', owner: 'ไอซ์', start: fmt(today), due: fmt(addDays(today,1)), remind: 1, status: 'เสร็จแล้ว', pct: 100, checklist: ['เช็คสต๊อก','สั่งซื้อ','รับของ'].map(t=>({t,done:true})), notes: '' },
    { id: 6, name: 'บานอสังสโตน M', group: 'งานตัด', owner: 'ไอซ์', start: fmt(today), due: fmt(addDays(today,4)), remind: 1, status: 'ยังไม่เริ่ม', pct: 0, checklist: ['วัดไซส์','ตัดผ้า','เย็บ','QC'].map(t=>({t,done:false})), notes: 'วางแผน/ดำเนินการต่อไป' },
    { id: 7, name: 'ส่งต่องานค้างของแต่ละสาขา', group: 'หน้าร้าน', owner: 'ตาล', start: fmt(addDays(today,-1)), due: fmt(today), remind: 1, status: 'เสร็จแล้ว', pct: 100, checklist: ['รวบรวมรายการ','ส่งต่อ','ยืนยัน'].map(t=>({t,done:true})), notes: '' },
  ];

  state.morningTalks = [
    { id: 1, date: fmt(today), branch: 'Online', topic: 'ติดตามยอดขาย', progress: '100%', owner: 'ผู้จัดการ', note: 'ยอดดีขึ้น' },
    { id: 2, date: fmt(today), branch: 'O.X.', topic: 'ตรวจสต๊อก', progress: '75%', owner: 'ไอซ์', note: 'รอของเพิ่ม' },
  ];
}

// ═══════════════════════════════════════
// DATES & ALERTS
// ═══════════════════════════════════════
function today() { return new Date().toISOString().split('T')[0]; }
function thaiDate(d) {
  if (!d) return '—';
  const months = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];
  const x = new Date(d + 'T00:00:00');
  return `${x.getDate()} ${months[x.getMonth()]} ${x.getFullYear()+543}`;
}
function daysUntil(dueStr) {
  const now = new Date(today()+'T00:00:00');
  const due = new Date(dueStr+'T00:00:00');
  return Math.round((due-now)/(1000*60*60*24));
}

function getTaskStatus(task) {
  if (task.status === 'เสร็จแล้ว') return 'done';
  const d = daysUntil(task.due);
  if (d < 0) return 'overdue';
  if (d <= (task.remind||1)) return 'warning';
  return task.status === 'ยังไม่เริ่ม' ? 'notstarted' : 'inprog';
}

function buildNotifications() {
  const notifs = [];
  state.tasks.forEach(t => {
    const d = daysUntil(t.due);
    if (t.status === 'เสร็จแล้ว') return;
    if (d < 0) notifs.push({ type:'red', title:`⚠️ งานเกินกำหนด: ${t.name}`, desc:`ส่งวันที่ ${thaiDate(t.due)} — เกินมาแล้ว ${Math.abs(d)} วัน`, time: thaiDate(t.due), task: t });
    else if (d <= (t.remind||1)) notifs.push({ type:'amber', title:`⏰ ครบกำหนดพรุ่งนี้: ${t.name}`, desc:`ส่งวันที่ ${thaiDate(t.due)} — ผู้รับผิดชอบ: ${t.owner}`, time: thaiDate(t.due), task: t });
  });
  if (notifs.length === 0) notifs.push({ type:'green', title:'✅ ไม่มีงานเร่งด่วน', desc:'ทุกงานอยู่ในเวลาที่กำหนด', time:'ตอนนี้' });
  return notifs;
}

// ═══════════════════════════════════════
// LOGIN / LOGOUT
// ═══════════════════════════════════════
function doLogin() {
  const u = document.getElementById('login-user').value;
  if (!u) { alert('กรุณาเลือกชื่อผู้ใช้'); return; }
  const [display, role, owner] = u.split('|');
  state.currentUser = { display, role, owner };
  show('main-screen'); hide('login-screen');
  document.getElementById('bottom-nav').style.display = 'flex';
  initMain();
}
function doLogout() {
  state.currentUser = null;
  show('login-screen'); hide('main-screen');
  document.getElementById('bottom-nav').style.display = 'none';
}

// ═══════════════════════════════════════
// INIT
// ═══════════════════════════════════════
function initMain() {
  const d = new Date();
  const months = ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];
  const days = ['อาทิตย์','จันทร์','อังคาร','พุธ','พฤหัสบดี','ศุกร์','เสาร์'];
  document.getElementById('header-date').textContent = `วัน${days[d.getDay()]}ที่ ${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()+543}`;
  document.getElementById('header-user').textContent = state.currentUser.display;
  document.getElementById('mt-date-label').textContent = `ประจำวันที่ ${thaiDate(today())}`;
  renderAll();
}

function renderAll() {
  renderDashboard();
  renderMyTasks();
  renderTeam();
  renderNotifs();
}

// ═══════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════
function renderDashboard() {
  const tasks = state.tasks;
  const done = tasks.filter(t=>t.status==='เสร็จแล้ว').length;
  const inprog = tasks.filter(t=>t.status==='กำลังดำเนินการ').length;
  const overdue = tasks.filter(t=>getTaskStatus(t)==='overdue').length;
  document.getElementById('stat-total').textContent = tasks.length;
  document.getElementById('stat-done').textContent = done;
  document.getElementById('stat-inprog').textContent = inprog;
  document.getElementById('stat-overdue').textContent = overdue;

  // Alerts
  const ac = document.getElementById('alerts-section');
  ac.innerHTML = '';
  tasks.forEach(t => {
    const d = daysUntil(t.due);
    if (t.status === 'เสร็จแล้ว') return;
    if (d < 0) ac.innerHTML += `<div class="alert alert-red"><span class="alert-icon">⚠️</span><div><b>${t.name}</b><br>เกินกำหนด ${Math.abs(d)} วัน — ผู้รับผิดชอบ: ${t.owner}</div></div>`;
    else if (d <= (t.remind||1)) ac.innerHTML += `<div class="alert alert-amber"><span class="alert-icon">⏰</span><div><b>${t.name}</b><br>ครบกำหนด ${thaiDate(t.due)} — แจ้งเตือนล่วงหน้า ${t.remind} วัน</div></div>`;
  });

  // Dashboard tasks (top 6)
  const dt = document.getElementById('dashboard-tasks');
  const toShow = tasks.slice(0,6);
  dt.innerHTML = toShow.length ? toShow.map(t => taskItemHTML(t)).join('') : '<div class="empty-state">ยังไม่มีงาน</div>';

  // Morning talk today
  const mtList = document.getElementById('mt-today-list');
  const todayMTs = state.morningTalks.filter(m=>m.date===today());
  mtList.innerHTML = todayMTs.length ? todayMTs.map(m => `
    <div style="padding:8px 0;border-bottom:1px solid var(--border)">
      <div style="display:flex;justify-content:space-between;align-items:center">
        <span style="font-size:14px;font-weight:600">${m.topic}</span>
        <span class="task-badge ${m.progress==='100%'?'badge-green':m.progress>='50%'?'badge-amber':'badge-gray'}">${m.progress}</span>
      </div>
      <div style="font-size:12px;color:var(--text3);margin-top:2px">${m.branch} · ${m.owner}${m.note?` · ${m.note}`:''}</div>
    </div>
  `).join('') : '<div style="font-size:13px;color:var(--text3)">ยังไม่มีการบันทึก Morning Talk วันนี้</div>';
}

// ═══════════════════════════════════════
// TASK ITEM HTML
// ═══════════════════════════════════════
function taskItemHTML(t) {
  const s = getTaskStatus(t);
  const badges = { done:'badge-green', warning:'badge-amber', overdue:'badge-red', inprog:'badge-blue', notstarted:'badge-gray' };
  const labels = { done:'เสร็จแล้ว', warning:'ใกล้ครบกำหนด', overdue:'เกินกำหนด', inprog:'กำลังดำเนินการ', notstarted:'ยังไม่เริ่ม' };
  const pctColor = t.pct >= 80 ? '' : t.pct >= 40 ? 'mid' : 'low';
  return `<div class="task-item" onclick="openTaskDetail(${t.id})">
    <div class="task-check ${t.status==='เสร็จแล้ว'?'done':''}" onclick="event.stopPropagation();toggleDone(${t.id})">${t.status==='เสร็จแล้ว'?'✓':''}</div>
    <div class="task-info">
      <div class="task-name ${t.status==='เสร็จแล้ว'?'done-text':''}">${t.name}</div>
      <div class="task-meta">
        <span class="task-badge ${badges[s]}">${labels[s]}</span>
        <span>${t.owner}</span>
        <span>ส่ง ${thaiDate(t.due)}</span>
      </div>
      <div class="progress-bar mt8"><div class="progress-fill ${pctColor}" style="width:${t.pct}%"></div></div>
      <div style="font-size:11px;color:var(--text3);margin-top:2px">${t.pct}% · ${t.group}</div>
    </div>
  </div>`;
}

// ═══════════════════════════════════════
// MY TASKS
// ═══════════════════════════════════════
function renderMyTasks() {
  const filter = document.getElementById('filter-status')?.value || '';
  const owner = state.currentUser?.owner;
  let tasks = state.tasks;
  if (owner && owner !== 'ตาล/มุก') tasks = tasks.filter(t => t.owner === owner || t.owner === 'ทุกคน');
  if (filter) tasks = tasks.filter(t => {
    if (filter === 'เกินกำหนด') return getTaskStatus(t) === 'overdue';
    return t.status === filter;
  });
  const el = document.getElementById('my-tasks-list');
  el.innerHTML = tasks.length ? tasks.map(t => taskItemHTML(t)).join('') : '<div class="empty-state"><div class="empty-icon">✅</div>ไม่มีงานในกลุ่มนี้</div>';
}

// ═══════════════════════════════════════
// TEAM
// ═══════════════════════════════════════
function renderTeam() {
  const members = ['ทุกคน','ไอซ์','เนตร','ตาล','มุก','ทีมขาย'];
  const el = document.getElementById('team-list');
  el.innerHTML = members.map(m => {
    const tasks = state.tasks.filter(t => t.owner === m || (m==='ทุกคน' && t.owner==='ทุกคน'));
    if (!tasks.length) return '';
    const avg = tasks.length ? Math.round(tasks.reduce((a,b)=>a+b.pct,0)/tasks.length) : 0;
    const cls = avg >= 75 ? 'high' : avg >= 40 ? 'mid' : 'low';
    const initials = m.charAt(0);
    const colors = ['var(--accent)','var(--blue)','var(--green)','var(--amber)','#8B5CF6','#06B6D4'];
    const ci = members.indexOf(m) % colors.length;
    return `<div class="member-row" onclick="showMemberDetail('${m}')">
      <div class="member-avatar" style="background:${colors[ci]}">${initials}</div>
      <div class="member-info">
        <div class="member-name">${m}</div>
        <div class="member-role">${tasks.length} งาน · ${tasks.filter(t=>t.status==='เสร็จแล้ว').length} เสร็จ</div>
      </div>
      <div class="member-stats">
        <div class="member-pct ${cls}">${avg}%</div>
        <div style="font-size:10px;color:var(--text3)">เฉลี่ย</div>
      </div>
    </div>`;
  }).join('');
}

function showMemberDetail(m) {
  const tasks = state.tasks.filter(t => t.owner === m || (m==='ทุกคน'&&t.owner==='ทุกคน'));
  document.getElementById('member-detail-name').textContent = `งานของ ${m}`;
  document.getElementById('member-detail-tasks').innerHTML = tasks.length ? tasks.map(t=>taskItemHTML(t)).join('') : '<div class="empty-state">ไม่มีงาน</div>';
  document.getElementById('member-detail-section').style.display = 'block';
  document.getElementById('tab-team').scrollTop = 9999;
}

// ═══════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════
function renderNotifs() {
  const notifs = buildNotifications();
  const el = document.getElementById('notifs-list');
  el.innerHTML = notifs.map(n => `
    <div class="notif-item">
      <div class="notif-dot dot-${n.type}"></div>
      <div class="notif-content">
        <div class="notif-title">${n.title}</div>
        <div class="notif-desc">${n.desc}</div>
        <div class="notif-time">${n.time}</div>
      </div>
    </div>
  `).join('');
}

// ═══════════════════════════════════════
// TASK DETAIL
// ═══════════════════════════════════════
function openTaskDetail(id) {
  const t = state.tasks.find(x=>x.id===id);
  if (!t) return;
  state.editTaskId = id;
  const s = getTaskStatus(t);
  const badges = { done:'badge-green', warning:'badge-amber', overdue:'badge-red', inprog:'badge-blue', notstarted:'badge-gray' };
  const labels = { done:'เสร็จแล้ว', warning:'ใกล้ครบกำหนด', overdue:'เกินกำหนด', inprog:'กำลังดำเนินการ', notstarted:'ยังไม่เริ่ม' };
  const cl = (t.checklist||[]).map((c,i) => {
    const boxCls = c.done ? 'check-box checked' : 'check-box';
    const textCls = c.done ? 'checklist-text done' : 'checklist-text';
    const tick = c.done ? '✓' : '';
    return `<div class="checklist-item" onclick="toggleChecklist(${id},${i})"><div class="${boxCls}">${tick}</div><div class="${textCls}">${c.t}</div></div>`;
  }).join('');
  const d = daysUntil(t.due);
  const dLabel = d < 0 ? `<span style="color:var(--red)">เกินกำหนด ${Math.abs(d)} วัน</span>` : d === 0 ? `<span style="color:var(--amber)">ครบกำหนดวันนี้</span>` : `<span style="color:var(--green)">อีก ${d} วัน</span>`;
  document.getElementById('modal-detail-content').innerHTML = `
    <div class="detail-header">
      <div class="detail-title">${t.name}</div>
      <div class="detail-meta">
        <span class="task-badge ${badges[s]}">${labels[s]}</span>
        <span>${t.group}</span>
        <span>👤 ${t.owner}</span>
      </div>
    </div>
    <div style="padding:14px 16px;border-bottom:1px solid var(--border)">
      <div class="flex-between" style="margin-bottom:8px">
        <span style="font-size:13px;font-weight:600;color:var(--text2)">ความคืบหน้า</span>
        <span style="font-size:15px;font-weight:700;color:var(--accent)">${t.pct}%</span>
      </div>
      <div class="progress-bar"><div class="progress-fill ${t.pct>=80?'':t.pct>=40?'mid':'low'}" style="width:${t.pct}%"></div></div>
      <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--text3);margin-top:8px">
        <span>เริ่ม ${thaiDate(t.start)}</span>
        <span>ส่ง ${thaiDate(t.due)} · ${dLabel}</span>
      </div>
    </div>
    ${t.checklist?.length ? `<div style="padding:10px 0"><div class="section-label" style="padding:8px 16px 4px">เช็คลิสต์ (${t.checklist.filter(c=>c.done).length}/${t.checklist.length})</div>${cl}</div>` : ''}
    ${t.notes ? `<div style="padding:12px 16px;font-size:13px;color:var(--text2);background:var(--surface2)">📝 ${t.notes}</div>` : ''}
  `;
  openModal('modal-detail');
}

function toggleChecklist(taskId, idx) {
  const t = state.tasks.find(x=>x.id===taskId);
  if (!t) return;
  t.checklist[idx].done = !t.checklist[idx].done;
  const done = t.checklist.filter(c=>c.done).length;
  t.pct = Math.round(done/t.checklist.length*100);
  if (t.pct === 100) t.status = 'เสร็จแล้ว';
  else if (t.pct > 0) t.status = 'กำลังดำเนินการ';
  saveState(); openTaskDetail(taskId); renderAll();
}

function toggleDone(id) {
  const t = state.tasks.find(x=>x.id===id);
  if (!t) return;
  t.status = t.status==='เสร็จแล้ว' ? 'กำลังดำเนินการ' : 'เสร็จแล้ว';
  if (t.status==='เสร็จแล้ว') { t.pct=100; t.checklist?.forEach(c=>c.done=true); }
  saveState(); renderAll();
}

// ═══════════════════════════════════════
// ADD / EDIT TASK
// ═══════════════════════════════════════
function openAddTask() {
  state.editTaskId = null;
  document.getElementById('modal-task-title').textContent = 'เพิ่มงานใหม่';
  document.getElementById('task-name').value = '';
  document.getElementById('task-group').value = 'หน้าร้าน';
  document.getElementById('task-owner').value = state.currentUser?.owner || 'ทุกคน';
  document.getElementById('task-start').value = today();
  document.getElementById('task-due').value = today();
  document.getElementById('task-remind').value = '1';
  document.getElementById('task-checklist').value = '';
  document.getElementById('task-status').value = 'ยังไม่เริ่ม';
  document.getElementById('task-pct').value = 0;
  document.getElementById('task-pct-val').textContent = '0%';
  openModal('modal-task');
}

function editCurrentTask() {
  const t = state.tasks.find(x=>x.id===state.editTaskId);
  if (!t) return;
  closeModal('modal-detail');
  document.getElementById('modal-task-title').textContent = 'แก้ไขงาน';
  document.getElementById('task-name').value = t.name;
  document.getElementById('task-group').value = t.group;
  document.getElementById('task-owner').value = t.owner;
  document.getElementById('task-start').value = t.start || today();
  document.getElementById('task-due').value = t.due;
  document.getElementById('task-remind').value = t.remind || 1;
  document.getElementById('task-checklist').value = (t.checklist||[]).map(c=>c.t).join('\n');
  document.getElementById('task-status').value = t.status;
  document.getElementById('task-pct').value = t.pct;
  document.getElementById('task-pct-val').textContent = t.pct + '%';
  openModal('modal-task');
}

function saveTask() {
  const name = document.getElementById('task-name').value.trim();
  if (!name) { alert('กรุณากรอกหัวข้องาน'); return; }
  const clText = document.getElementById('task-checklist').value.trim();
  const cl = clText ? clText.split('\n').filter(x=>x.trim()).map(t=>({t:t.trim(),done:false})) : [];
  const pct = parseInt(document.getElementById('task-pct').value);
  if (state.editTaskId) {
    const t = state.tasks.find(x=>x.id===state.editTaskId);
    if (t) {
      t.name = name; t.group = document.getElementById('task-group').value;
      t.owner = document.getElementById('task-owner').value;
      t.start = document.getElementById('task-start').value;
      t.due = document.getElementById('task-due').value;
      t.remind = parseInt(document.getElementById('task-remind').value);
      t.status = document.getElementById('task-status').value;
      t.pct = pct;
      if (cl.length) { const oldDone = new Set((t.checklist||[]).filter(c=>c.done).map(c=>c.t)); t.checklist = cl.map(c=>({...c,done:oldDone.has(c.t)})); }
    }
  } else {
    const newId = (state.tasks.length ? Math.max(...state.tasks.map(t=>t.id)) : 0) + 1;
    state.tasks.push({ id: newId, name, group: document.getElementById('task-group').value, owner: document.getElementById('task-owner').value, start: document.getElementById('task-start').value, due: document.getElementById('task-due').value, remind: parseInt(document.getElementById('task-remind').value), status: document.getElementById('task-status').value, pct, checklist: cl, notes: '' });
  }
  saveState(); closeModal('modal-task'); renderAll();
}

