// ═══════════════════════════════════════
// LINE NOTIFY INTEGRATION
// ═══════════════════════════════════════


function buildLineMessage() {
  const d = new Date();
  const months = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];
  const days = ['อาทิตย์','จันทร์','อังคาร','พุธ','พฤหัสบดี','ศุกร์','เสาร์'];
  const dateStr = 'วัน' + days[d.getDay()] + 'ที่ ' + d.getDate() + ' ' + months[d.getMonth()] + ' ' + (d.getFullYear()+543);

  let msg = '\n☀️ Morning Talk — ฮันเฮง\n📅 ' + dateStr + '\n';
  msg += '─────────────────\n';

  // Overdue
  const overdue = state.tasks.filter(t => t.status !== 'เสร็จแล้ว' && daysUntil(t.due) < 0);
  if (overdue.length) {
    msg += '\n🚨 งานเกินกำหนด (' + overdue.length + ' งาน)\n';
    overdue.forEach(t => {
      msg += '⛔ ' + t.name + '\n   👤 ' + t.owner + ' | ครบ ' + thaiDate(t.due) + ' | ' + t.pct + '%\n';
    });
  }

  // Warnings
  const warn = state.tasks.filter(t => {
    if (t.status === 'เสร็จแล้ว') return false;
    const d = daysUntil(t.due);
    return d >= 0 && d <= (t.remind||1);
  });
  if (warn.length) {
    msg += '\n⏰ ใกล้ครบกำหนด (' + warn.length + ' งาน)\n';
    warn.forEach(t => {
      const dl = daysUntil(t.due);
      const u = dl === 0 ? '🔴 วันนี้!' : dl === 1 ? '🟡 พรุ่งนี้' : '🟢 อีก ' + dl + ' วัน';
      msg += '📌 ' + t.name + '\n   👤 ' + t.owner + ' | ' + u + ' | ' + t.pct + '%\n';
    });
  }

  // Today's Morning Talk entries
  const todayMTs = state.morningTalks.filter(m => m.date === today());
  if (todayMTs.length) {
    msg += '\n📋 รายงานวันนี้ (' + todayMTs.length + ' รายการ)\n';
    todayMTs.forEach(m => {
      msg += '• ' + m.topic + ' [' + m.progress + '] — ' + m.owner;
      if (m.note) msg += '\n  💬 ' + m.note;
      msg += '\n';
    });
  }

  // Summary
  const total = state.tasks.length;
  const done = state.tasks.filter(t => t.status === 'เสร็จแล้ว').length;
  msg += '\n📊 ภาพรวม: ' + done + '/' + total + ' งานเสร็จ';
  if (!overdue.length && !warn.length) msg += '\n✅ ไม่มีงานเร่งด่วน';

  return msg;
}

function sendDailyReportToLine() {
  const msg = buildLineMessage();
  const encoded = encodeURIComponent(msg);
  const lineUrl = 'https://line.me/R/share?text=' + encoded;
  showToast('📤 กำลังเปิด LINE...');
  setTimeout(() => { window.open(lineUrl, '_blank'); }, 300);
}

// ── Toast notification ──
function showToast(msg) {
  let el = document.getElementById('toast');
  if (!el) {
    el = document.createElement('div');
    el.id = 'toast';
    el.style.cssText = 'position:fixed;bottom:100px;left:50%;transform:translateX(-50%);background:#1A1814;color:white;padding:10px 20px;border-radius:20px;font-size:14px;z-index:9999;transition:opacity 0.3s;max-width:300px;text-align:center;';
    document.body.appendChild(el);
  }
  el.textContent = msg;
  el.style.opacity = '1';
  clearTimeout(el._t);
  el._t = setTimeout(() => { el.style.opacity = '0'; }, 2800);
}

